# 复制为 .env.prod 后填写【必填】项（.env.prod 勿提交 Git）
# cp .env.example .env.prod
#
# deploy/data/.voiceprint.yaml 里 server.authorization 【必填】与智控台声纹配置一致（可从测试复制）
# MySQL 连接由上方环境变量覆盖 yaml 中的 host，无需改 yaml 里的 host

# =============================================================================
# 【必填】RDS MySQL（与 xiaozhi 同一实例，库名 voiceprint_db）
# =============================================================================
MYSQL_RDS_HOST=
MYSQL_RDS_PORT=3306
MYSQL_DATABASE=voiceprint_db
MYSQL_RDS_USER=
MYSQL_RDS_PASSWORD=

# =============================================================================
# 【必填】ACR 镜像（deploy/prod/images 构建 push 后填写；勿 docker compose --build）
# =============================================================================
VOICEPRINT_IMAGE=crpi-q9r33h1cqhy6qssk.cn-beijing.personal.cr.aliyuncs.com/zhiban_agent/voiceprint-api:v1.0.0

# =============================================================================
# 端口
# =============================================================================
APP_PORT=8005
