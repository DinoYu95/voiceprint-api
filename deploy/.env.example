# 复制为 .env 后按需修改：cp .env.example .env
# 镜像内通过 Dockerfile 安装 requirements.txt，启动命令为 python start_server.py

# ----- 声纹服务端口（需与 data/.voiceprint.yaml 里 server.port 一致，默认 8005） -----
APP_PORT=8005

# ----- 使用预构建镜像时设置（不设则 docker compose up -d --build 从源码构建） -----
# VOICEPRINT_IMAGE=voiceprint-api:latest
# VOICEPRINT_IMAGE=ghcr.nju.edu.cn/xinnan-tech/voiceprint-api:latest
